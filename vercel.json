{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "winefeed.se" }],
      "destination": "https://www.winefeed.se/:path",
      "permanent": true
    }
  ],
  "crons": [{
    "path": "/api/cron/access-reminders",
    "schedule": "0 7 * * *"
  }, {
    "path": "/api/cron/food-trends",
    "schedule": "0 6 1 * *"
  }, {
    "path": "/api/cron/daily-digest",
    "schedule": "30 4 * * *"
  }]
}
